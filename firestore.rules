rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; // Universal deny
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Leaderboard
    function isValidLeaderboardEntry(data) {
      return data.keys().hasAll(['userId', 'nickname', 'score', 'gameMode', 'createdAt'])
        && data.keys().size() == 5
        && data.userId == request.auth.uid
        && data.nickname is string && data.nickname.size() > 0 && data.nickname.size() <= 30
        && data.score is number && data.score >= 0
        && (data.gameMode == 'classic' || data.gameMode == 'kombo')
        && data.createdAt == request.time;
    }

    match /leaderboard/{entryId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidLeaderboardEntry(incoming());
      // Allow update if the user owns the entry OR if they are submitting a higher score for this nickname
      // (Deriving "ownership" by nickname via the deterministic ID used in the service)
      allow update: if isSignedIn() 
        && isValidLeaderboardEntry(incoming()) 
        && (
          existing().userId == request.auth.uid || 
          incoming().score > existing().score
        );
      // Only owner can delete their entries
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    // Matches
    function isValidMatchCreate(data) {
      return data.keys().hasAll(['hostId', 'inviteCode', 'status', 'gameMode', 'playerIds', 'players', 'createdAt', 'updatedAt'])
        && data.hostId == request.auth.uid
        && data.inviteCode is string && data.inviteCode.size() == 6
        && data.status == 'waiting'
        && (data.gameMode == 'classic' || data.gameMode == 'kombo')
        && data.playerIds is list && data.playerIds.size() == 1 && data.playerIds[0] == request.auth.uid
        && data.players is map && data.players.keys().hasAll([request.auth.uid])
        && data.players[request.auth.uid] is map
        && data.players[request.auth.uid].keys().hasAll(['nickname'])
        && data.players[request.auth.uid].nickname is string && data.players[request.auth.uid].nickname.size() <= 30
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function isValidMatchUpdate(data) {
      return data.hostId is string
        && data.inviteCode is string
        && (data.status == 'waiting' || data.status == 'playing' || data.status == 'finished')
        && (data.gameMode == 'classic' || data.gameMode == 'kombo')
        && data.playerIds is list && data.playerIds.size() <= 6 && data.playerIds.size() > 0
        && data.players is map
        && data.updatedAt == request.time;
    }

    function isJoinAction() {
      let diff = incoming().diff(existing());
      return existing().status == 'waiting'
        && diff.affectedKeys().hasOnly(['playerIds', 'players', 'updatedAt'])
        // Add current user to player list
        && incoming().playerIds.size() == existing().playerIds.size() + 1
        && request.auth.uid in incoming().playerIds
        && request.auth.uid in incoming().players;
    }

    function isStartAction() {
      let diff = incoming().diff(existing());
      return existing().hostId == request.auth.uid
        && existing().status == 'waiting'
        && incoming().status == 'playing'
        // Allow adding game state keys: 'currentTurnUserId', 'diceValues', 'heldDice', 'rollsLeft', 'scores', 'playersOrder', 'turnIndex', 'diceRolledInLastAction'
        && diff.affectedKeys().hasOnly(['status', 'updatedAt', 'currentTurnUserId', 'diceValues', 'heldDice', 'rollsLeft', 'scores', 'playersOrder', 'turnIndex', 'diceRolledInLastAction', 'column3NextRow', 'column4NextRow'])
        && incoming().playersOrder is list
        && incoming().turnIndex == 0;
    }

    function isMoveAction() {
      let diff = incoming().diff(existing());
      return existing().status == 'playing'
        && existing().currentTurnUserId == request.auth.uid  // Ensure it's the user's turn
        // Allow updating the game state fields
        && diff.affectedKeys().hasAny([
          'diceValues', 'heldDice', 'rollsLeft', 'scores',
          'currentTurnUserId', 'turnIndex', 'diceRolledInLastAction',
          'column3NextRow', 'column4NextRow', 'status', 'updatedAt'
        ]);
    }

    function isLeaveAction() {
      let diff = incoming().diff(existing());
      
      let isWaitingLeave = existing().status == 'waiting'
        && (
             // Everyone left
             (incoming().status == 'finished' && diff.affectedKeys().hasOnly(['status', 'updatedAt']))
             ||
             // Someone left (maybe host)
             (incoming().playerIds.size() < existing().playerIds.size()
              && !(request.auth.uid in incoming().playerIds)
              && diff.affectedKeys().hasOnly(['playerIds', 'hostId', 'updatedAt'])
             )
           );

      let isPlayingLeave = (existing().status == 'playing' || existing().status == 'finished')
        && incoming().players[request.auth.uid].hasLeft == true
        && diff.affectedKeys().hasOnly([
            'players', 'status', 'updatedAt',
            'currentTurnUserId', 'turnIndex', 'rollsLeft', 
            'diceValues', 'heldDice', 'diceRolledInLastAction'
        ]);

      return isWaitingLeave || isPlayingLeave;
    }

    match /matches/{matchId} {
      // Anyone who is in the game or just querying via invite code (needs to read to join)
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(matchId) && isValidMatchCreate(incoming());
      allow update: if isSignedIn()
        && incoming().inviteCode == existing().inviteCode // Immortal
        && incoming().createdAt == existing().createdAt // Immortal
        && isValidMatchUpdate(incoming())
        && (
             isJoinAction() ||
             isStartAction() ||
             isMoveAction() ||
             isLeaveAction()
           );
    }
  }
}
